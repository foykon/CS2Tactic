spring:
  application:
    name: cs2tactic-api
  datasource:
    url: jdbc:postgresql://127.0.0.1:PORT/DB_NAME
    username: DB_USER
    password: DB_PASSWORD
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    open-in-view: false

server:
  port: 8080